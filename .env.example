# =============================================================================
# Speech-to-Speech Pipeline - environment configuration
# -----------------------------------------------------------------------------
# Copy this file to ".env" and adjust values as needed:
#     Windows:      copy .env.example .env
#     macOS/Linux:  cp .env.example .env
#
# IMPORTANT: This project is 100% free and runs locally.
#            NO paid API keys are required anywhere.
# =============================================================================

# Hugging Face access token.
# Only needed if you use a GATED Hugging Face model. The default Whisper and
# XTTS v2 models used here are open and do NOT require it, so you can leave it
# blank. If you ever need one, create a FREE token (free account required) at:
#   https://huggingface.co/settings/tokens
HF_TOKEN=

# Whisper model size. Larger = more accurate but slower and more memory.
# Options: tiny | base | small | medium | large-v3
WHISPER_MODEL_SIZE=base

# Language XTTS v2 should speak in (ISO code): en, es, fr, de, it, pt, hi, ...
XTTS_LANGUAGE=en

# Compute device.
# Use "cuda" if you have an NVIDIA GPU available (much faster),
# otherwise use "cpu".
DEVICE=cpu
