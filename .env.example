# Copy this file to ".env" and fill in real values. Never commit ".env".
# ---------------------------------------------------------------------------

# --- Whisper (ASR) settings ---
# Model size: tiny | base | small | medium | large
WHISPER_MODEL_SIZE=small
# Source language of the podcast (ISO code), or leave blank for auto-detect
SOURCE_LANGUAGE=en

# --- Translation / target language ---
TARGET_LANGUAGE=en

# --- XTTS v2 (TTS) settings ---
XTTS_MODEL_NAME=tts_models/multilingual/multi-dataset/xtts_v2
# Coqui may require accepting its license non-interactively:
COQUI_TOS_AGREED=1

# --- Optional third-party API keys (only if you add cloud services) ---
# OPENAI_API_KEY=
# HUGGINGFACE_TOKEN=
