# =============================================================================
# Speech-to-Speech Pipeline .gitignore
# Large binaries and secrets are excluded; empty folder structure is kept
# tracked via .gitkeep placeholders.
# =============================================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
build/
dist/
*.egg-info/

# --- Virtual environments ---
venv_xtts
venv/
.venv/
env/
ENV/
*/venv/
*/.venv/

# --- Secrets / environment ---
.env
*.env
!.env.example

# --- Input data (large audio) — keep folders, ignore contents ---
data/raw/*
data/reference_voices/*
!data/**/.gitkeep

# --- Outputs (transcripts, audio, logs) — keep folders, ignore contents ---
outputs/**/*
!outputs/**/
!outputs/**/.gitkeep

# --- Model weights (per module) — keep folders, ignore contents ---
*/models/*
!*/models/.gitkeep

# --- Logs ---
*.log

# --- Notebooks ---
.ipynb_checkpoints/

# --- IDE / OS ---
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
